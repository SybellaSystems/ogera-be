PORT = 5000
NODE_ENV = env
BASE_URL = base url

DB_PORT = db port
DB_USERNAME = db username
DB_PASSWORD = db password
DB_NAME = db name
DB_HOST = host
DB_DIALECT = dialect
DB_USE_SSL = false (set to true for cloud databases like Neon, AWS RDS, etc. Auto-detected if host is not localhost)

JWT_ACCESS_TOKEN_SECRET = JWT secret

EMAIL_USER = xyz@gmail.com
EMAIL_PASS = app password

# MTN MoMo API (Ogera_Get_Paid - Collections). Use your sandbox/live credentials.
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=your_collection_subscription_key
MOMO_USER_ID=your_collection_api_user_id
MOMO_API_KEY=your_collection_api_key
MOMO_TARGET_ENV=sandbox
# Ogera fee: employer pays job amount + this % (e.g. 10 = 10%, job 1000 → employer pays 1100)
MOMO_SERVICE_FEE_PERCENT=10
MOMO_CURRENCY=RWF

# MTN MoMo Disbursement (pay students from Ogera wallet)
MOMO_DISBURSEMENT_SUBSCRIPTION_KEY=your_disbursement_subscription_key
MOMO_DISBURSEMENT_USER_ID=your_disbursement_api_user_id
MOMO_DISBURSEMENT_API_KEY=your_disbursement_api_key
