{
    "name": "ogera-backend",
    "version": "1.0.0",
    "description": "ogera backend",
    "main": "server.ts",
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "start": "npm run build && node dist/server.js",
        "dev": "nodemon",
        "build": "tsc && tsc-alias && echo 'Build Finished! 👍'",
        "lint": "eslint --ignore-path .gitignore --ext .ts src/",
        "lint:fix": "npm run lint -- --fix",
        "db:init": "node -r ts-node/register -r tsconfig-paths/register src/scripts/db-init.ts",
        "migration:generate": "sequelize migration:generate --name",
        "migration": "sequelize db:migrate",
        "seed": "sequelize db:seed:all",
        "seed:undo": "sequelize db:seed:undo:all",
        "seed:undo:all": "sequelize db:seed:undo:all"
    },
    "author": "Prashant",
    "license": "MIT",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.943.0",
        "@aws-sdk/s3-request-presigner": "^3.943.0",
        "@types/multer": "^2.0.0",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "disposable-email-domains": "^1.0.62",
        "dotenv": "^16.4.5",
        "express": "^4.21.2",
        "express-rate-limit": "^8.0.1",
        "helmet": "^8.1.0",
        "http-status-codes": "^2.3.0",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.0.2",
        "nodemailer": "^7.0.5",
        "pesapal-v3": "^0.3.1",
        "pg": "^8.17.2",
        "pg-hstore": "^2.3.4",
        "qrcode": "^1.5.4",
        "sequelize": "^6.37.4",
        "sequelize-typescript": "^2.1.6",
        "speakeasy": "^2.0.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "tsconfig-paths": "^4.2.0",
        "twilio": "^5.12.0",
        "validator": "^13.15.15",
        "winston": "^3.15.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.10.5",
        "@types/nodemailer": "^7.0.1",
        "@types/pg": "^8.11.10",
        "@types/qrcode": "^1.5.5",
        "@types/sequelize": "^4.28.20",
        "@types/speakeasy": "^2.0.10",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.6",
        "@typescript-eslint/eslint-plugin": "^5.29.0",
        "@typescript-eslint/parser": "^5.29.0",
        "eslint": "^8.20.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-prettier": "^4.2.1",
        "jest": "^29.7.0",
        "nodemon": "^3.1.7",
        "prettier": "^2.7.1",
        "sequelize-cli": "^6.6.2",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.10",
        "typescript": "^5.7.3"
    }
}
