{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@routes/*": ["routes/*"],
      "@database/*": ["database/*"],
      "@utils/*": ["utils/*"],
      "@types/*": ["types/*"],
      "@modules/*": ["modules/*"]
    },
    "esModuleInterop": true,
    "typeRoots": ["node_modules/@types"],
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["esnext"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*.ts", "src/database/models/index.ts"],
  "exclude": ["node_modules"]
}
